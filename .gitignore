# Used by dotenv library to load environment variables.
.env
.env.*
node_modules
vendor/bundle

# Ignore Byebug command history file.
.byebug_history

## Specific to RubyMotion:
.dat*
.repl_history
build/
*.bridgesupport
build-iPhoneOS/
build-iPhoneSimulator/

